{
  "name": "cypress-expose",
  "version": "1.0.0",
  "description": "Expose public variables via CYPRESS_EXPOSE process variables",
  "main": "index.js",
  "files": [
    "index.js"
  ],
  "scripts": {
    "dev": "CYPRESS_EXPOSE_PUBLIC_VARIABLE_1=foo CYPRESS_EXPOSE_PUBLIC_VARIABLE_2=bar CYPRESS_EXPOSE_PUBLIC_VARIABLE_3=baz cypress open",
    "test": "CYPRESS_EXPOSE_PUBLIC_VARIABLE_1=foo CYPRESS_EXPOSE_PUBLIC_VARIABLE_2=bar CYPRESS_EXPOSE_PUBLIC_VARIABLE_3=baz cypress run"
  },
  "keywords": [
    "cypress",
    "cypress-plugin"
  ],
  "author": "Gleb Bahmutov <gleb.bahmutov@gmail.com>",
  "license": "ISC",
  "devDependencies": {
    "cypress": "^15.11.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3"
  },
  "dependencies": {
    "to-camel-case": "^1.0.0"
  }
}
